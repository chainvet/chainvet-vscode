{
  "name": "chainvet",
  "displayName": "Chainvet — Smart Contract Auditor",
  "description": "Analyze Solidity smart contracts for security vulnerabilities inside VS Code, via the Chainvet language server.",
  "version": "0.1.0",
  "publisher": "chainvet",
  "license": "MIT",
  "icon": "media/chainvet-icon.png",
  "categories": ["Linters", "Programming Languages", "Other"],
  "keywords": ["solidity", "smart contract", "security", "audit", "static analysis", "ethereum"],
  "engines": { "vscode": "^1.85.0" },
  "repository": { "type": "git", "url": "https://github.com/chainvet/chainvet-vscode" },
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:solidity", "workspaceContains:**/*.sol", "onView:chainvetFindings"],
  "contributes": {
    "configuration": {
      "title": "Chainvet",
      "properties": {
        "chainvet.serverPath": {
          "type": "string",
          "default": "chainvet-lsp",
          "description": "Path to the chainvet-lsp language server binary (on PATH by default)."
        },
        "chainvet.cliPath": {
          "type": "string",
          "default": "chainvet",
          "description": "Path to the chainvet CLI binary, used for on-demand full hybrid scans (on PATH by default)."
        },
        "chainvet.aiReports.enabled": {
          "type": "boolean",
          "default": false,
          "description": "AI review of findings via a local Ollama. Drops likely false positives and annotates findings, but adds latency to each scan."
        },
        "chainvet.aiFallbackParser.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Use the AI fallback parser when both solc and tree-sitter fail to parse a file (requires a local Ollama)."
        },
        "chainvet.ai.endpoint": {
          "type": "string",
          "default": "http://127.0.0.1:11434",
          "description": "Ollama endpoint for the AI features."
        },
        "chainvet.ai.model": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Ollama model for the AI features."
        }
      }
    },
    "languages": [
      {
        "id": "solidity",
        "aliases": ["Solidity", "solidity"],
        "extensions": [".sol"]
      }
    ],
    "commands": [
      {
        "command": "chainvet.restartServer",
        "title": "Chainvet: Restart Language Server"
      },
      {
        "command": "chainvet.hybridScan",
        "title": "Full Hybrid Scan (Current File)",
        "category": "Chainvet",
        "icon": "$(play)"
      },
      {
        "command": "chainvet.refreshFindings",
        "title": "Refresh Findings",
        "category": "Chainvet",
        "icon": "$(refresh)"
      },
      {
        "command": "chainvet.clearFindings",
        "title": "Clear Findings",
        "category": "Chainvet",
        "icon": "$(clear-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "chainvet",
          "title": "Chainvet",
          "icon": "media/chainvet-sidebar.png"
        }
      ]
    },
    "views": {
      "chainvet": [
        {
          "id": "chainvetFindings",
          "name": "Findings"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        { "command": "chainvet.hybridScan", "when": "resourceLangId == solidity" }
      ],
      "editor/title": [
        { "command": "chainvet.hybridScan", "when": "resourceLangId == solidity", "group": "navigation" }
      ],
      "view/title": [
        { "command": "chainvet.refreshFindings", "when": "view == chainvetFindings", "group": "navigation@1" },
        { "command": "chainvet.clearFindings", "when": "view == chainvetFindings", "group": "navigation@2" }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
